# ─── MeshNet Client — .env.example ────────────────────────────────────────────
# Copy to client/.env and fill in values before running locally.
# All VITE_ variables are inlined at build time — never put secrets here.

# ── Signaling server ──────────────────────────────────────────────────────────
# Local dev:  http://localhost:3001
# Production: https://meshnet-signaling.onrender.com
VITE_SIGNALING_URL=http://localhost:3001

# ── Default disaster zone ─────────────────────────────────────────────────────
# Users join this zone automatically on first load.
# Override per-device from the Settings drawer.
VITE_DEFAULT_ZONE=zone-alpha

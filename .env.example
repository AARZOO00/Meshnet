# ─── MeshNet Root .env.example ────────────────────────────────────────────────
# This file documents ALL environment variables used across the project.
# Copy the relevant sections to server/.env and client/.env respectively.

# ════════════════════════════════════════════════
#  SERVER  (copy to server/.env)
# ════════════════════════════════════════════════

# HTTP port for the signaling server
PORT=3001

# Set to 'production' on Render / any cloud host
NODE_ENV=development

# Comma-separated list of allowed frontend origins
# Local:       http://localhost:5173,http://localhost:3000
# Production:  https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Maximum simultaneous nodes per disaster zone
MAX_NODES_PER_ZONE=100

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# ════════════════════════════════════════════════
#  CLIENT  (copy to client/.env)
#  All VITE_ vars are inlined at build time.
#  Never put secrets here.
# ════════════════════════════════════════════════

# Full URL of the running signaling server
# Local dev:   http://localhost:3001
# Production:  https://meshnet-signaling.onrender.com
VITE_SIGNALING_URL=http://localhost:3001

# Zone nodes auto-join on first load
# Can be overridden per-device in the Settings drawer
VITE_DEFAULT_ZONE=zone-alpha
